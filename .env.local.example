# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Secret — NEVER expose this to the client bundle (server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create API Key
# Free tier: 3,000 emails/month
# Also verify your sending domain in Resend → Domains (or emails go to spam)
RESEND_API_KEY=re_your_api_key_here

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to "true" to show demo credentials on the login screen
NEXT_PUBLIC_DEMO_MODE=false

# ─── Claude AI (Prime CRM) ────────────────────────────────────────────────────
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Groq AI (fallback) ────────────────────────────────────────────────────────
# Get your API key from https://console.groq.com
# If unset, defaults to embedded key (fallback for demo/testing)
GROQ_API_KEY=gsk_your-key-here

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# rate-limit mode: "memory" (default, in-process) or "upstash" (future)
RATE_LIMIT_MODE=memory

# Daily AI cost cap per user (dollars; applies to all AI calls)
AI_DAILY_COST_CAP_USD=20

# ─── Cron security ────────────────────────────────────────────────────────────
# Generate a 32+ char random string (e.g., `openssl rand -hex 32`)
# Used to authenticate Vercel cron calls to /api/cron/scan
CRON_SECRET=generate-a-random-32-char-string

# ─── Sentry (optional) ─────────────────────────────────────────────────────────
# Sign up at https://sentry.io → Projects → Next.js → DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=sntrys_eyJ...
